# WordPress REST API base URL (path must include /wp-json). Server-only — do not use
# NEXT_PUBLIC_* here or the value can ship in the browser bundle.
# Copy to `.env.local` for local overrides. Set in hosting (e.g. Netlify/Vercel) for production.
WORDPRESS_API_URL=https://your-site.com/wp-json

# --- Book checkout: PayPal (https://developer.paypal.com/) ---
# Sandbox base: https://api-m.sandbox.paypal.com
# Live base: https://api-m.paypal.com
# PAYPAL_CLIENT_ID is PayPal’s public REST “Client ID” (safe in the browser); we still load it
# server-side only so it is not inlined via NEXT_PUBLIC_* into unrelated client chunks.
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Order notification email (Resend: https://resend.com — free tier) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=notifications@yourdomain.com
ORDER_NOTIFICATION_EMAIL=orders@yourdomain.com
